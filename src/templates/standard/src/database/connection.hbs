import { Sequelize } from 'sequelize';
import { config } from '../configs/app.config.js';

export const sequelize = new Sequelize({
  dialect: 'sqlite',
  storage: config.db.storage,
  logging: config.env === 'development' ? console.log : false,
});

export const connectDatabase = async (){{#if (eq language "typescript")}}: Promise<void>{{/if}} => {
  try {
    await sequelize.authenticate();
    // sync({ alter: true }) updates the table structure if the model changes.
    // Use sync({ force: true }) to drop and recreate tables (WARNING: deletes all data).
    // For production, use migrations instead.
    await sequelize.sync({ alter: true });
    console.log('\nDatabase connected and synced successfully');
  } catch (error) {
    console.error('\nUnable to connect to the database:', error);
    process.exit(1);
  }
};
