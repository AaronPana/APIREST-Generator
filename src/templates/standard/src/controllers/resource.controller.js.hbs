  getById = async (req, res, next) => {
    try {
      const { id } = req.params;
      const data = await this.store.getById(id);
      if (!data) throw ApiError.notFound('{{pascalCase}} not found');
      res.status(HttpStatus.OK).json({ success: true, data });
    } catch (error) {
      next(error);
    }
  };

  create = async (req, res, next) => {
    try {
      const body = create{{pascalCase}}Schema.parse(req.body);
      const data = await this.store.create(body);
      res.status(HttpStatus.CREATED).json({ success: true, data });
    } catch (error) {
      next(error);
    }
  };

  update = async (req, res, next) => {
    try {
      const { id } = req.params;
      const body = update{{pascalCase}}Schema.parse(req.body);
      const data = await this.store.update(id, body);
      if (!data) throw ApiError.notFound('{{pascalCase}} not found');
      res.status(HttpStatus.OK).json({ success: true, data });
    } catch (error) {
      next(error);
    }
  };

  delete = async (req, res, next) => {
    try {
      const { id } = req.params;
      const deleted = await this.store.delete(id);
      if (!deleted) throw ApiError.notFound('{{pascalCase}} not found');
      res.status(HttpStatus.NO_CONTENT).send();
