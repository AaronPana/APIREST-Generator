import { create{{pascalCase}}Schema, update{{pascalCase}}Schema } from '../schemas/{{singular}}.schema.js';
import { ApiError } from '../errors/ApiError.js';
import { HttpStatus } from '../errors/HttpStatus.js';

export class {{pascalCase}}Controller {
  constructor(store) {
    this.store = store;
  }

  getAll = async (_req, res, next) => {
    try {
      const data = await this.store.getAll();
      res.status(HttpStatus.OK).json({ success: true, data });
    } catch (error) {
      next(error);
