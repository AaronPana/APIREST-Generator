{
  "name": "{{name}}",
  "version": "0.1.0",
  "description": "{{description}}",
  {{#if (eq language "typescript")}}
    "main": "dist/index.js",
  {{else}}
    "main": "index.js",
  {{/if}}
  {{#if (eq language "typescript")}}
    "bin": {
      "{{name}}": "./dist/index.js"
    },
  {{/if}}
  "scripts": {
    {{#if (eq language "typescript")}}
    "build": "tsc",
    "dev": "tsx watch{{#if (and (ne level 'basic') (ne level 'standard'))}} --env-file=.env{{/if}} src/index.ts",
    "start": "node{{#if (and (ne level 'basic') (ne level 'standard'))}} --env-file=.env{{/if}} dist/index.js",
    "lint": "tsc --noEmit",
    {{else}}
    "dev": "nodemon{{#if (and (ne level 'basic') (ne level 'standard'))}} --env-file=.env{{/if}} src/index.js",
    "start": "node{{#if (and (ne level 'basic') (ne level 'standard'))}} --env-file=.env{{/if}} src/index.js",
    {{/if}}
    {{#if prettier}}
    "format": "prettier --write \"src/**/*.{{#if (eq language 'typescript')}}ts{{else}}js{{/if}}\""
    {{/if}}
  },
  "author": "",
  "license": "",
  "type": "module",
  "dependencies": {
    {{#each dependencies}}
    "{{@key}}": "{{this}}"{{#unless @last}},{{/unless}}
    {{/each}}
  },
  "devDependencies": {
    {{#each devDependencies}}
    "{{@key}}": "{{this}}"{{#unless @last}},{{/unless}}
    {{/each}}
  },
  "engines": {
    "node": ">=20.6.0"
  }
}
