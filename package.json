{
  "name": "apirest-generator",
  "version": "0.1.0",
  "description": "CLI to generate production-ready REST APIs with Node.js, Express and TypeScript",
  "main": "dist/index.js",
  "bin": {
    "apirest-gen": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "cli",
    "rest-api",
    "generator",
    "express",
    "typescript"
  ],
  "author": "",
  "license": "",
  "type": "module",
  "dependencies": {
    "@inquirer/prompts": "^5.0.0",
    "chalk": "^5.3.0",
    "fs-extra": "^11.2.0",
    "handlebars": "^4.7.8",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.14.0",
    "prettier": "^3.3.0",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.6.0"
  }
}
